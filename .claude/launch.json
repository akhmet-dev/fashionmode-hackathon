{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Web Dev Server",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "8080"],
      "port": 8080
    },
    {
      "name": "Flutter Web (headless)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "3000"],
      "port": 3000
    }
  ]
}
